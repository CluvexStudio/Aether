config aether 'main'

	option enabled '0'
	option protocol 'masque'
	option socks_listen '0.0.0.0:1819'
	option scan_mode 'balanced'
	option ip_version 'ipv4'
	option obfuscation_profile 'firewall'
	option http2_mode '0'
	option h2_peer ''
	option fragment_tls '0'
	option fragment_size '16-32'
	option fragment_delay '2-10'
	option peer ''
	option keepalive '5'
	option reconnect_secs '2'
	option validate_secs '10'
	option quick_reconnect '0'
	option no_data_check '0'
	option config_path '/etc/aether/aether.toml'
	option log_level 'info'
